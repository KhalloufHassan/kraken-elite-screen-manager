# Allow non-root access to the NZXT Kraken 2023 Elite (1e71:300c) so
# KrakenEliteScreenManager can drive the LCD without sudo.
#
# Grants the active logged-in user access (uaccess, via systemd-logind) plus a
# 0660 group fallback. Covers BOTH interfaces we use:
#   - the raw USB device  -> libusb bulk endpoint (image upload)
#   - the hidraw node      -> HID control channel (brightness, status, buckets)
#
# Install: see scripts/install-udev.sh

# GROUP="wheel" gives immediate access on `udevadm trigger` (no replug/reboot
# needed, since uaccess only applies on a real kernel add event). uaccess is
# kept so it keeps working cleanly across reboots/replugs too.
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="300c", MODE="0660", GROUP="wheel", TAG+="uaccess"
KERNEL=="hidraw*", ATTRS{idVendor}=="1e71", ATTRS{idProduct}=="300c", MODE="0660", GROUP="wheel", TAG+="uaccess"
